---
const currentYear = new Date().getFullYear();
---
<footer
  class="displayLap"
  style="background-color: #080715; color: #fff;"
>
  <div style="padding: 50px 120px 30px; padding-right: 100px;">
    <!-- Top row -->
    <div
      style="display: grid; grid-template-columns: 1.2fr 1.8fr 1fr 1fr; gap: 80px; align-items: start;"
    >
      <!-- Logo + locations -->
      <div>
        <a href="/">
          <img src="/images/nitco-images/LogoWhite.svg" alt="NITCO" width="180" height="44" />
        </a>
        <div style="margin-top: 32px;">
          <p style="display: flex; align-items: center; font-size: 14px; color: #fff; margin-bottom: 10px;">
            <img src="/images/FooterDesignChange/USA.png" alt="USA" width="26" height="18" style="margin-right: 10px;" />
            USA - Texas
          </p>
          <p style="display: flex; align-items: center; font-size: 14px; color: #fff; margin: 0;">
            <img src="/images/FooterDesignChange/Indian.png" alt="India" width="26" height="18" style="margin-right: 10px;" />
            India - Hyderabad
          </p>
        </div>
      </div>

      <!-- Solutions -->
      <div>
        <h3 style="color: #fff; font-size: 16px; font-weight: 700; margin-bottom: 18px;">Solutions</h3>
        <a href="/solutions/working-capital-spend-integrity" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          Working Capital &amp; Spend Integrity Program
        </a>
        <a href="/solutions/workflow-automation" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          Workflow Automation
        </a>
        <a href="/solutions/decision-ready-data" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          Decision-Ready Data Program
        </a>
        <a href="/solutions/employee-knowledge-productivity" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          Employee Knowledge &amp; Productivity
        </a>
        <a href="/solutions/customer-support-optimization" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          Customer Experience &amp; Support Optimization
        </a>
        <a href="/solutions/ai-solution-delivery" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          AI Solution Delivery
        </a>
        <a href="/solutions/ai-risk-cost-governance" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          AI Risk, Cost &amp; Governance
        </a>
      </div>

      <!-- Company -->
      <div>
        <h3 style="color: #fff; font-size: 16px; font-weight: 700; margin-bottom: 18px;">Company</h3>
        <a href="/company/about" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          About
        </a>
        <a href="/company/careers/" style="color: #fff; font-size: 14px; text-decoration: none; display: block; margin-bottom: 10px; opacity: 0.95;">
          Careers
        </a>
      </div>

      <!-- Follow Us + Contact -->
      <div style="text-align: right;">
        <h3 style="color: #fff; font-size: 16px; font-weight: 700; margin-bottom: 18px; text-align: right;">Follow Us</h3>
        <div style="margin-bottom: 32px;">
          <a
            href="https://www.facebook.com/NitcoIncOfficial/"
            target="_blank"
            rel="noreferrer"
            style="display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: #fff; margin-right: 10px;"
          >
            <img src="/images/FooterDesignChange/fb.svg" alt="Facebook" width="16" height="16" />
          </a>
          <a
            href="https://twitter.com/nitcoofficial/"
            target="_blank"
            rel="noreferrer"
            style="display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: #fff; margin-right: 10px;"
          >
            <img src="/images/FooterDesignChange/X.svg" alt="X" width="14" height="14" />
          </a>
          <a
            href="https://www.linkedin.com/company/nitcoincofficial"
            target="_blank"
            rel="noreferrer"
            style="display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: #fff; margin-right: 10px;"
          >
            <img src="/images/FooterDesignChange/linkdin.svg" alt="LinkedIn" width="16" height="16" />
          </a>
          <a
            href="https://www.youtube.com/channel/UChm0AxXJl4gsIiUimX1kh-A"
            target="_blank"
            rel="noreferrer"
            style="display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: #fff; margin-right: 0;"
          >
            <img src="/images/FooterDesignChange/youtube.svg" alt="YouTube" width="16" height="16" />
          </a>
        </div>
        <h3 style="color: #fff; font-size: 16px; font-weight: 700; margin-bottom: 18px; text-align: right;">Contact Us</h3>
        <a
          href="mailto:YourPartner@nitcoinc.com"
          style="color: #fff; font-size: 14px; text-decoration: none; opacity: 0.95;"
        >
          YourPartner@nitcoinc.com
        </a>
      </div>
    </div>

    <!-- Divider + bottom bar -->
    <div
      style="border-top: 1px solid rgba(255,255,255,0.18); margin-top: 40px; padding-top: 22px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;"
    >
      <div style="display: flex; gap: 32px;">
        <a href="/privacy-policy" style="color: #fff; font-size: 13px; text-decoration: none;">
          Privacy Policy
        </a>
        <a href="/cookie-policy" style="color: #fff; font-size: 13px; text-decoration: none;">
          Cookie Policy
        </a>
      </div>
      <p style="color: #fff; font-size: 13px; margin: 0; opacity: 0.85;">
        &copy; {currentYear} Nitco, Inc. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .displayLap {
    display: block;
  }
  @media (max-width: 1000px) {
    .displayLap {
      display: none;
    }
  }
</style>
