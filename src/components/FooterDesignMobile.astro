---
const currentYear = new Date().getFullYear();
---
<footer class="displayMobile">
  <div class="footerWrapper">
    <!-- Logo -->
    <div class="logoSection">
      <a href="/">
        <img src="/images/nitco-images/LogoWhite.svg" alt="logo" width="180" height="40" />
      </a>
    </div>

    <!-- Tablet Layout -->
    <div class="tabletLayout">
      <!-- Solutions -->
      <div class="section">
        <h3>Solutions</h3>
        <div class="linksInline">
          <a href="/solutions/working-capital-spend-integrity/">Working Capital &amp; Spend Integrity Program</a>
          <span>|</span>
          <a href="/solutions/workflow-automation/">Workflow Automation</a>
          <span>|</span>
          <a href="/solutions/decision-ready-data/">Decision-Ready Data Program</a>
          <span>|</span>
          <a href="/solutions/employee-knowledge-productivity/">Employee Knowledge &amp; Productivity</a>
          <span>|</span>
          <a href="/solutions/customer-support-optimization/">Customer Experience &amp; Support Optimization</a>
          <span>|</span>
          <a href="/solutions/ai-solution-delivery/">AI Solution Delivery</a>
          <span>|</span>
          <a href="/solutions/ai-risk-cost-governance/">AI Risk, Cost &amp; Governance</a>
        </div>
      </div>

      <div class="companySocialRow">
        <!-- Company -->
        <div class="section">
          <h3>Company</h3>
          <div class="linksInline">
            <a href="/company/about/">About</a>
            <span>|</span>
            <a href="/company/careers/">Careers</a>
          </div>
        </div>

        <!-- Social -->
        <div class="section">
          <h3>Follow Us</h3>
          <div class="socialWrapper">
            <a
              href="https://www.facebook.com/NitcoIncOfficial/"
              target="_blank"
              rel="noreferrer"
              class="socialCircle"
            >
              <img src="/images/FooterDesignChange/fb.svg" alt="Facebook" width="20" height="20" />
            </a>
            <a
              href="https://twitter.com/nitcoofficial/"
              target="_blank"
              rel="noreferrer"
              class="socialCircle"
            >
              <img src="/images/FooterDesignChange/X.svg" alt="X" width="20" height="20" />
            </a>
            <a
              href="https://www.linkedin.com/company/nitcoincofficial"
              target="_blank"
              rel="noreferrer"
              class="socialCircle"
            >
              <img src="/images/FooterDesignChange/linkdin.svg" alt="LinkedIn" width="20" height="20" />
            </a>
            <a
              href="https://www.youtube.com/channel/UChm0AxXJl4gsIiUimX1kh-A"
              target="_blank"
              rel="noreferrer"
              class="socialCircle"
            >
              <img src="/images/FooterDesignChange/youtube.svg" alt="YouTube" width="20" height="20" />
            </a>
          </div>
        </div>
      </div>

      <!-- Address Section -->
      <div class="addressSection">
        <div class="divider"></div>
        <div class="addressRow">
          <img src="/images/FooterDesignChange/USA.png" alt="USA" width="26" height="18" />
          <div>
            <p><strong>US Headquarters:</strong> 440 Cobia Dr., Suite 1701 Katy, Texas 77494</p>
            <span>281-503-7002</span>
          </div>
        </div>
        <div class="divider"></div>
        <div class="addressRow">
          <img src="/images/FooterDesignChange/Indian.png" alt="India" width="26" height="18" />
          <div>
            <p><strong>India Hyderabad:</strong> 514-515, 5th Floor DSL Abacus IT Park, IDA Uppal, Hyderabad, Telangana 500013, India.</p>
            <span>040-45437549</span>
            <p class="mt10">Gachibowli, Hyderabad, Telangana 500032, India</p>
            <span>040-45437626</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Layout -->
    <div class="mobileLayout">
      <div class="mobileSection">
        <h3>Solutions</h3>
        <a href="/solutions/working-capital-spend-integrity/">Working Capital &amp; Spend Integrity Program</a>
        <a href="/solutions/workflow-automation/">Workflow Automation</a>
        <a href="/solutions/decision-ready-data/">Decision-Ready Data Program</a>
        <a href="/solutions/employee-knowledge-productivity/">Employee Knowledge &amp; Productivity</a>
        <a href="/solutions/customer-support-optimization/">Customer Experience &amp; Support Optimization</a>
        <a href="/solutions/ai-solution-delivery/">AI Solution Delivery</a>
        <a href="/solutions/ai-risk-cost-governance/">AI Risk, Cost &amp; Governance</a>
      </div>

      <div class="mobileSection">
        <h3>Company</h3>
        <a href="/company/about/">About</a>
        <a href="/company/careers/">Careers</a>
      </div>

      <div class="mobileSection">
        <h3>Follow Us</h3>
        <div class="socialWrapper">
          <a href="https://www.facebook.com/NitcoIncOfficial/" target="_blank" rel="noreferrer">
            <img src="/images/FooterDesignChange/fb.svg" alt="Facebook" width="20" height="20" />
          </a>
          <a href="https://twitter.com/nitcoofficial/" target="_blank" rel="noreferrer">
            <img src="/images/FooterDesignChange/X.svg" alt="X" width="20" height="20" />
          </a>
          <a href="https://www.linkedin.com/company/nitcoincofficial" target="_blank" rel="noreferrer">
            <img src="/images/FooterDesignChange/linkdin.svg" alt="LinkedIn" width="20" height="20" />
          </a>
          <a href="https://www.youtube.com/channel/UChm0AxXJl4gsIiUimX1kh-A" target="_blank" rel="noreferrer">
            <img src="/images/FooterDesignChange/youtube.svg" alt="YouTube" width="20" height="20" />
          </a>
        </div>
      </div>

      <div class="mobileSection">
        <h3>Contact Us</h3>
        <a href="mailto:YourPartner@nitcoinc.com">YourPartner@nitcoinc.com</a>
      </div>

      <div class="mobileCountry">
        <div>
          <img src="/images/FooterDesignChange/USA.png" alt="USA" width="26" height="18" />
          <span>USA - Texas</span>
        </div>
        <div>
          <img src="/images/FooterDesignChange/Indian.png" alt="India" width="26" height="18" />
          <span>India - Hyderabad</span>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="bottomBar">
      <div class="policyLinks">
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/cookie-policy/">Cookie Policy</a>
      </div>
      <p>&copy; {currentYear} Nitco, Inc. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
.displayMobile {
  display: none;
}

@media (max-width: 1000px) {
  .displayMobile {
    display: block;
    color: #fff;
  }
}

.footerWrapper {
  padding: 40px 20px 20px;
}

.logoSection {
  display: flex;
  justify-content: center;
  margin-bottom: 30px;
}

/* TABLET */
.tabletLayout {
  display: block;
}

.linksInline {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}

.linksInline a {
  color: #fff;
  text-decoration: none;
  font-size: 12px;
}

.linksInline span {
  color: #fff;
}

.companySocialRow {
  display: flex;
  gap: 40px;
  margin-top: 30px;
}

.section h3 {
  font-size: 15px;
  margin-bottom: 12px;
  color: #fff;
}

.socialWrapper {
  display: flex;
  gap: 10px;
}

.socialCircle {
  width: 28px;
  height: 28px;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.socialCircle img {
  width: 14px;
  height: 14px;
}

.addressSection {
  margin-top: 25px;
}

.divider {
  border-top: 1px solid rgba(255,255,255,0.3);
  margin: 15px 0;
}

.addressRow {
  display: flex;
  gap: 10px;
}

.addressRow img {
  width: 28px;
  height: 18px;
  margin-top: 4px;
}

.addressRow p,
.addressRow span {
  font-size: 12px;
  line-height: 1.7;
  margin: 0;
}

.mt10 {
  margin-top: 10px !important;
}

/* MOBILE */
.mobileLayout {
  display: none;
}

.bottomBar {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.2);
}

.policyLinks {
  display: flex;
  gap: 20px;
  margin-bottom: 12px;
}

.policyLinks a {
  color: #fff;
  font-size: 12px;
  text-decoration: none;
}

.bottomBar p {
  font-size: 12px;
  margin: 0;
}

/* MOBILE VIEW */
@media (max-width: 420px) {
  .tabletLayout {
    display: none;
  }

  .mobileLayout {
    display: block;
  }

  .mobileSection {
    margin-bottom: 30px;
  }

  .mobileSection h3 {
    margin-bottom: 16px;
    font-size: 16px;
  }

  .mobileSection a {
    display: block;
    color: #fff;
    text-decoration: none;
    margin-bottom: 14px;
    font-size: 14px;
  }

  .mobileCountry {
    border-top: 1px solid rgba(255,255,255,0.2);
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding: 20px 0;
  }

  .mobileCountry div {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .mobileCountry div:first-child {
    margin-bottom: 20px;
  }

  .mobileCountry img {
    width: 28px;
    height: 18px;
  }

  .mobileCountry span {
    font-size: 14px;
  }
}
</style>
