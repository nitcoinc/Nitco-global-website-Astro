---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found | NITCO Inc."
  description="The page you were looking for could not be found."
  path="/404"
>
  <main style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:70vh;padding:4rem 1.5rem;text-align:center;font-family:inherit;">
    <p style="font-size:7rem;font-weight:800;line-height:1;margin:0;color:#0a2540;letter-spacing:-4px;">404</p>
    <h1 style="font-size:2rem;font-weight:700;margin:1rem 0 0.75rem;color:#0a2540;">Page Not Found</h1>
    <p style="font-size:1.125rem;color:#4a5568;max-width:480px;margin:0 0 2.5rem;">
      The page you were looking for doesn&rsquo;t exist or has been moved. Let&rsquo;s get you back on track.
    </p>
    <a
      href="/"
      style="display:inline-block;background:#0a2540;color:#ffffff;font-size:1rem;font-weight:600;padding:0.875rem 2.25rem;border-radius:6px;text-decoration:none;transition:background 0.2s;"
      onmouseover="this.style.background='#1a3a5c'"
      onmouseout="this.style.background='#0a2540'"
    >
      Back to Homepage
    </a>
  </main>
</BaseLayout>
