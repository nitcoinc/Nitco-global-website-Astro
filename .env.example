# ─── TinaCMS / TinaCloud ────────────────────────────────────────────────────
# Get these from https://app.tina.io → your project → Overview
TINA_TOKEN=
NEXT_PUBLIC_TINA_CLIENT_ID=
NEXT_PUBLIC_TINA_BRANCH=main

# ─── TinaCMS Database (GitHub provider) ─────────────────────────────────────
# Used by tina/database.js in cloud mode (TINA_PUBLIC_IS_LOCAL != true)
GITHUB_OWNER=pmandapati-nitcoinc
GITHUB_REPO=Nitco-global-website-v1
GITHUB_BRANCH=main
GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── MongoDB (TinaCMS datalayer storage) ────────────────────────────────────
MONGODB_URI=

# ─── Auth (NextAuth / TinaCMS auth) ─────────────────────────────────────────
# Required if tinacms-authjs auth provider is enabled
NEXTAUTH_SECRET=

# ─── Local development only ──────────────────────────────────────────────────
# Set to true to use local filesystem instead of TinaCloud (dev only)
# TINA_PUBLIC_IS_LOCAL=true
